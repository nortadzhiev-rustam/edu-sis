{
  "cli": {
    "version": ">= 16.7.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "hooks": {
        "preInstall": "scripts/eas-build-pre-install.sh",
        "postInstall": "scripts/ios-firebase-setup.sh"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "hooks": {
        "preInstall": "scripts/eas-build-pre-install.sh",
        "postInstall": "scripts/ios-firebase-setup.sh"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:assembleRelease",
        "image": "latest",
        "buildType": "apk",
        "env": {
          "GRADLE_OPTS": "-Dorg.gradle.daemon=false -Dorg.gradle.jvmargs=-Xmx4g"
        }
      },
      "ios": {
        "buildConfiguration": "Release"
      },
      "channel": "production",
      "env": {
        "EXPO_NO_CAPABILITY_SYNC": "1",
        "GOOGLE_SERVICES_INFOPLIST_PATH": "./GoogleService-Info.plist",
        "GOOGLE_SERVICES_JSON_PATH": "./google-services.json"
      },
      "hooks": {
        "preInstall": "scripts/eas-build-pre-install.sh",
        "postInstall": "scripts/ios-firebase-setup.sh"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
